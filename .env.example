# --- App / Deployment ---
# Public base URL used in server-rendered links and email templates.
# Must include scheme + no trailing slash. Falls back to APP_BASE_URL
# server-side; both should match in prod. Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Inngest (automation runtime)
# Dev: not required - Inngest Dev Server runs keyless locally
# Prod: required - create an app at https://app.inngest.com, copy these from the app's "Keys" page
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cloudflare R2 (object storage for evidence uploads)
# Create an R2 bucket + API token at https://dash.cloudflare.com → R2.
# R2_ENDPOINT is the full "S3 API" URL Cloudflare shows for the bucket
# (e.g. https://<accountid>.r2.cloudflarestorage.com). All five are required.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=policydraft
# R2_PUBLIC_URL MUST be a publicly reachable domain for the bucket
# (a Cloudflare custom domain or R2 public bucket URL). The private
# *.r2.cloudflarestorage.com S3 endpoint is NOT browser-reachable.
# Configure: Dashboard → R2 → bucket → Settings → Public access → enable
# (or attach a custom domain) and paste that URL here.
R2_PUBLIC_URL=https://files.example.com

# --- Resend (transactional email) ---
# Create API key at https://resend.com/api-keys. Required in prod;
# dev/tests: leave unset and email helpers silently no-op.
RESEND_API_KEY=
# Verified sender address. Resend rejects unverified domains.
RESEND_FROM_ADDRESS=Civilization Lab <noreply@civilization-lab.com>
# P11: Reply-To target so stakeholder replies to system emails land in a
# monitored mailbox rather than bouncing off noreply@. Optional - falls back
# to RESEND_FROM_ADDRESS when unset, but production should always set it.
SUPPORT_EMAIL=support@civilization-lab.com

# Groq (LLM: Whisper transcription + llama summarization)
# Create API key at https://console.groq.com/keys
# Free tier: 25MB audio file limit for Whisper
GROQ_API_KEY=

# --- Cloudflare Turnstile (Phase 19 public intake form) ---
# Site key is public, embedded in the browser widget
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=0x00000000000000000000AA
# Secret key is server-side only, used for /siteverify POST
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000AA

# Cardano Preview-Net Anchoring (Phase 23)
CARDANO_WALLET_MNEMONIC=       # 24-word seed phrase for preview-net wallet
BLOCKFROST_PROJECT_ID=         # Must start with 'preview' (e.g. previewXXXXXXXX)

# Workshop Feedback Deep-Link JWT (Phase 20)
# Any random 32+ character secret. Used to sign/verify JWT tokens in workshop feedback email deep-links.
WORKSHOP_FEEDBACK_JWT_SECRET=

# --- Google Calendar (workshop booking) ---
# OAuth credentials from Google Cloud Console (APIs & Services → Credentials).
# Create an OAuth 2.0 Client ID (Web application type). The refresh token is
# obtained by running the bootstrap script: scripts/bootstrap-google-oauth.ts
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Email address of the Google account that owns the calendar used for workshops.
# Must match the account the OAuth refresh token was granted for.
WORKSHOP_ORGANIZER_EMAIL=
# Google Calendar ID to create workshop events on. Use 'primary' for the
# account's primary calendar, or paste a specific calendar ID from
# Google Calendar Settings → (calendar) → Integrate calendar.
GOOGLE_CALENDAR_ID=primary
