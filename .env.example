# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Inngest (automation runtime)
# Dev: not required — Inngest Dev Server runs keyless locally
# Prod: required — create an app at https://app.inngest.com, copy these from the app's "Keys" page
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cloudflare R2 (object storage for evidence uploads)
# Create an R2 bucket + API token at https://dash.cloudflare.com → R2.
# R2_ENDPOINT is the full "S3 API" URL Cloudflare shows for the bucket
# (e.g. https://<accountid>.r2.cloudflarestorage.com). All five are required.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=policydraft
R2_PUBLIC_URL=https://<bucket>.<account-id>.r2.cloudflarestorage.com

# Groq (LLM: Whisper transcription + llama summarization)
# Create API key at https://console.groq.com/keys
# Free tier: 25MB audio file limit for Whisper
GROQ_API_KEY=

# --- Cloudflare Turnstile (Phase 19 public intake form) ---
# Site key is public, embedded in the browser widget
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=0x00000000000000000000AA
# Secret key is server-side only, used for /siteverify POST
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000AA
